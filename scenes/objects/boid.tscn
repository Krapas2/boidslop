[sub_resource type="Shader" id="Shader_2degq"]
code = "shader_type particles;

uniform sampler3D curl_base;
uniform vec3 curl_scale;
uniform float curl_strength;


vec2 normal_from_tex(sampler3D tex, vec3 uv)
{
	float h_top = textureLod(tex, uv + vec3(0., 1., 0.), 0.).x;
	float h_bottom = textureLod(tex, uv + vec3(0., -1., 0.), 0.).x;
	float h_right = textureLod(tex, uv + vec3(1.0, 0.0, 0.), 0.).x;
	float h_left = textureLod(tex, uv + vec3(-1., 0., 0.), 0.).x;

	vec2 diff = vec2(h_right - h_left, h_top - h_bottom);
	return normalize(diff);
}

vec3 curl(vec2 pos)
{
	vec3 uv = vec3(pos, TIME) * curl_scale;
	vec2 normal = normal_from_tex(curl_base, uv) * curl_strength;
	return vec3(-normal.y, normal.x, 0.);
}

void start() {
	
}

void process() {
    VELOCITY = curl(TRANSFORM[3].xy);
}
"

